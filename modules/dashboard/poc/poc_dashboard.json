    {
      "id": 7184341610684890,
      "definition": {
        "title": "Top Endpoints - ClubeIFood",
        "title_size": "16",
        "title_align": "left",
        "type": "query_table",
        "requests": [
          {
            "queries": [
              {
                "data_source": "apm_metrics",
                "name": "query1",
                "stat": "hits",
                "service": "clubeifood-valebonus-bff",
                "group_by": [
                  "resource_name"
                ],
                "query_filter": "resource_name:*"
              },
              {
                "data_source": "apm_metrics",
                "name": "query2",
                "stat": "latency_max",
                "service": "clubeifood-valebonus-bff",
                "group_by": [
                  "resource_name"
                ],
                "query_filter": "resource_name:*"
              },
              {
                "data_source": "apm_metrics",
                "name": "query3",
                "stat": "errors",
                "service": "clubeifood-valebonus-bff",
                "group_by": [
                  "resource_name"
                ],
                "query_filter": "resource_name:*"
              },
              {
                "data_source": "apm_metrics",
                "name": "query4",
                "stat": "latency_p99",
                "service": "clubeifood-valebonus-bff",
                "group_by": [
                  "resource_name"
                ],
                "query_filter": "resource_name:*"
              },
              {
                "data_source": "apm_metrics",
                "name": "query5",
                "stat": "latency_p95",
                "service": "clubeifood-valebonus-bff",
                "group_by": [
                  "resource_name"
                ],
                "query_filter": "resource_name:*"
              },
              {
                "data_source": "apm_metrics",
                "name": "query6",
                "stat": "latency_p95",
                "service": "clubeifood-valebonus-bff",
                "group_by": [
                  "resource_name"
                ],
                "query_filter": "resource_name:*"
              },
              {
                "data_source": "apm_metrics",
                "name": "query7",
                "stat": "latency_p95",
                "service": "clubeifood-valebonus-bff",
                "group_by": [
                  "resource_name"
                ],
                "query_filter": "resource_name:*"
              }
            ],
            "response_format": "scalar",
            "sort": {
              "count": 10,
              "order_by": [
                {
                  "type": "formula",
                  "index": 0,
                  "order": "desc"
                }
              ]
            },
            "formulas": [
              {
                "cell_display_mode": "bar",
                "alias": "Requisições",
                "conditional_formats": [
                  {
                    "comparator": ">=",
                    "value": 1,
                    "palette": "white_on_green"
                  }
                ],
                "formula": "query1"
              },
              {
                "cell_display_mode": "number",
                "conditional_formats": [
                  {
                    "comparator": ">",
                    "value": 5000,
                    "palette": "white_on_yellow"
                  }
                ],
                "alias": "Latencia P95",
                "formula": "query2"
              },
              {
                "cell_display_mode": "bar",
                "alias": "Erros",
                "conditional_formats": [
                  {
                    "comparator": "=",
                    "value": 0,
                    "palette": "white_on_green"
                  },
                  {
                    "comparator": "<",
                    "value": 50,
                    "palette": "white_on_yellow"
                  },
                  {
                    "comparator": ">",
                    "value": 50,
                    "palette": "white_on_red"
                  }
                ],
                "formula": "query3"
              },
              {
                "cell_display_mode": "bar",
                "conditional_formats": [
                  {
                    "comparator": "<",
                    "value": 5,
                    "palette": "white_on_green"
                  },
                  {
                    "comparator": "<",
                    "value": 30,
                    "palette": "white_on_yellow"
                  },
                  {
                    "comparator": ">=",
                    "value": 30,
                    "palette": "white_on_red"
                  }
                ],
                "formula": "query4"
              },
              {
                "alias": "Diff",
                "formula": "query2 - calendar_shift(query5, '-1w', 'America/Sao_Paulo')"
              },
              {
                "alias": "Diff 2W",
                "formula": "query2 - calendar_shift(query6, '-2w', 'America/Sao_Paulo')"
              },
              {
                "alias": "Diff Month",
                "formula": "query2 - calendar_shift(query7, '-1mo', 'America/Sao_Paulo', 'preserve_duration')"
              }
            ]
          }
        ],
        "has_search_bar": "auto"
      },
      "layout": {
        "x": 6,
        "y": 3,
        "width": 6,
        "height": 6
      }
    },
